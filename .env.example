# ============================================================================
# 환경변수 템플릿
# .env.development (개발) 또는 .env.production (프로덕션)으로 복사하여 사용
# ============================================================================

# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# TOSS Payments (test_ck_ = 테스트, live_ck_ = 라이브)
EXPO_PUBLIC_TOSS_CLIENT_KEY=test_ck_your-test-client-key

# Sentry (선택)
EXPO_PUBLIC_SENTRY_DSN=

# Mixpanel (선택)
EXPO_PUBLIC_MIXPANEL_TOKEN=
